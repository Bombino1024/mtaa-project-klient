<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddSleepRecordActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <Button
            android:id="@+id/pickDateSleepRecord"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:onClick="pickDateSleepRecord"
            android:text="Fall Asleep Date" />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/fallAsleepTime"
            android:text="Fall Asleep time"
            android:onClick="pickFallAsleepTime"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/pickWakeUpDate"
            android:onClick="pickWakeUpDate"
            android:text="Wake Up Date"/>

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/wakeUpTime"
            android:text="Wake Up Time"
            android:onClick="pickWakeUpTime"/>

        <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:gravity="bottom">

            <Button
                android:id="@+id/storeSleepRecord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:onClick="storeSleepRecord"
                android:text="Confirm" />

        </RelativeLayout>
        </LinearLayout>

</RelativeLayout>